# ===== Local Runtime =====
HF_MODEL_NAME=Qwen/Qwen3.5-4B
LLAMA_SERVER_URL=http://127.0.0.1:8080
DLLM_SERVER_URL=http://127.0.0.1:8081
# Optional if llama-server.exe is outside the project
LLAMA_SERVER_EXE=

# ===== Cloud LLMs =====
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
CLOUD_MODEL_NAME=llama-3.3-70b-versatile

GOOGLE_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
TOGETHER_MODEL_NAME=Qwen/Qwen3-32B

# ===== Medical APIs =====
NCBI_EMAIL=
NCBI_API_KEY=
TAVILY_API_KEY=
ICD11_CLIENT_ID=
ICD11_CLIENT_SECRET=

# ===== Runtime Settings =====
LOG_LEVEL=INFO
DEBUG=false
OPERATION_MODE_DEFAULT=local_core_with_online_r2

RUNTIME_PROFILE_DEFAULT=auto
RUNTIME_PROFILE_VRAM_GB_OVERRIDE=0
RUNTIME_PROFILE_COMPACT_CTX=4096
RUNTIME_PROFILE_COMPACT_MAX_ITERATIONS=2
RUNTIME_PROFILE_COMPACT_MIN_ITERATIONS=1
RUNTIME_PROFILE_COMPACT_R2_MAX_QUERIES=4

MAX_RRRIE_ITERATIONS=3
MIN_RRRIE_ITERATIONS=2
CONFIDENCE_THRESHOLD=0.85
IMPROVEMENT_DELTA=0.05
MIN_EVIDENCE_SOURCES=2
STAGNATION_THRESHOLD=2

ENTROPY_ROUTER_MODE=disabled
ENTROPY_ROUTER_THRESHOLD_SIMPLE=0.45
ENTROPY_ROUTER_THRESHOLD_MODERATE=0.90
ENTROPY_ROUTER_THRESHOLD_COMPLEX=1.35
ENTROPY_ROUTER_MARGIN=0.12
ENTROPY_ROUTER_TOP_LOGPROBS=8
ENTROPY_ROUTER_PROBE_TOKENS=3
ENTROPY_ROUTER_USE_4B_FALLBACK=true

MATH_IE_MODE=disabled
MATH_IE_TOP_LOGPROBS=6
MATH_IE_PROBE_TOKENS=1
MATH_IE_ENTROPY_THRESHOLD=0.52
MATH_IE_JSD_THRESHOLD=0.08

# ===== vNext Label Quality Gates =====
CDSS_LEARNED_LABEL_QUALITY_ENABLED=true
CDSS_LEARNED_LABEL_QUALITY_THRESHOLD=0.52
CDSS_REGISTRY_PRIOR_ENABLED=false
CDSS_STATIC_PATTERN_MAP_ENABLED=false
CDSS_LLM_RESEARCH_PLANNER_ENABLED=true
CDSS_EVIDENCE_CONFIDENCE_REQUIRES_VERIFIED_EDGES=true
CDSS_MAX_REASONING_LOOPS=8
CDSS_PUBMED_MAX_QUERIES=6
CDSS_PUBMED_MAX_RESULTS=4
CDSS_TAVILY_MAX_QUERIES=6
CDSS_ICD11_MAX_QUERIES=6
CDSS_RESEARCH_MIN_EVIDENCE_COVERAGE=0.68
CDSS_RESEARCH_MIN_VERIFIED_EDGES=2
CDSS_DETERMINISTIC_MECHANISM_FALLBACK_ENABLED=false
CDSS_STATE_MISMATCH_RULES_ENABLED=false
CDSS_MANUAL_REVIEW_ENABLED=false
